@page "/cards/{SetId:int}"
@using Microsoft.EntityFrameworkCore
@using PokeCollection.Data.Models
@using PokeCollection.Data.Services
@inject PokeCollection.Data.Services.PokemonApiService Api
@inject PokeCollection.Data.AppDbContext Db
@inject IJSRuntime JS

@if (isLoading)
{
    <div class="loading-overlay">
        <img src="/images/loading.svg" class="loading-spinner" alt="Carregando..." />
        <p class="loading-status">@loadingStatus</p>
    </div>
}
else
{
    <div class="cards-header">
        <div class="cards-header-top">
            <h3>@set?.Name</h3>
            <div class="cards-header-actions">
                <label class="masterset-toggle" title="Marcar as variações de cada carta">
                    <input type="checkbox" checked="@mastersetEnabled" @onchange="ToggleMasterset" />
                    <span class="masterset-slider"></span>
                    <span class="masterset-text">Masterset</span>
                </label>
                <button class="missing-log-btn @(missingLog is not null ? "active" : "")" @onclick="ToggleMissingLog">
                    📋 Cartas faltantes
                </button>
                @if (newCardsAdded > 0 || newImagesLoaded > 0)
                {
                    <div class="cards-sync-toast">
                        @if (newCardsAdded > 0)
                        {
                            <span>✨ @newCardsAdded nova@(newCardsAdded > 1 ? "s cartas" : " carta") adicionada@(newCardsAdded > 1 ? "s" : "")</span>
                        }
                        @if (newImagesLoaded > 0)
                        {
                            <span>🖼️ @newImagesLoaded imagem@(newImagesLoaded > 1 ? "ns" : "") baixada@(newImagesLoaded > 1 ? "s" : "")</span>
                        }
                    </div>
                }
            </div>
        </div>
        <div class="cards-filters">
            <div class="sort-btns">
                <button class="sort-btn @(cardFilter == CardFilter.Todas ? "active" : "")"
                        @onclick="() => cardFilter = CardFilter.Todas">Todas</button>
                <button class="sort-btn @(cardFilter == CardFilter.Faltantes ? "active" : "")"
                        @onclick="() => cardFilter = CardFilter.Faltantes">Faltantes</button>
                <button class="sort-btn @(cardFilter == CardFilter.Adquiridas ? "active" : "")"
                        @onclick="() => cardFilter = CardFilter.Adquiridas">Adquiridas</button>
            </div>
            <input class="search-input" placeholder="Buscar por nome ou nº (ex: 120/180)" style="min-width:180px"
                   @oninput="e => cardNameFilter = e.Value?.ToString() ?? string.Empty" />
        </div>
    </div>

    @if (missingLog is not null)
    {
        <div class="missing-log-panel">
            <div class="missing-log-toolbar">
                <span class="missing-log-count">@missingCount carta@(missingCount != 1 ? "s" : "") faltante@(missingCount != 1 ? "s" : "")</span>
                <button class="sort-btn" @onclick="CopyLog">📋 Copiar</button>
            </div>
            <textarea class="missing-log-textarea" readonly>@missingLog</textarea>
        </div>
    }

    @if (!FilteredCards.Any())
    {
        <p>Nenhuma carta encontrada.</p>
    }
    else
    {
        <div class="cards-grid">
            @foreach (var c in FilteredCards)
            {
                var finalUrl = PokeCollection.Data.CardImage.BuildUrl(c.ImageSmallUrl, "low", "webp");
                var symbolUrl = set?.Symbol;
                <div class="card-item @(c.Owned ? "owned" : "")"
                     @onclick="() => ToggleOwned(c.Id, !c.Owned)"
                     title="@c.Name">

                    @if (c.Owned)
                    {
                        <span class="owned-badge">✓</span>
                    }

                    <button class="zoom-btn" @onclick="() => OpenModal(c)" @onclick:stopPropagation="true" title="Ver carta">
                        <span class="oi oi-magnifying-glass"></span>
                    </button>

                    <div class="card-img-wrap @(string.IsNullOrWhiteSpace(finalUrl) ? "img-missing" : "")">
                        <img class="card-img" src="@(string.IsNullOrWhiteSpace(finalUrl) ? Placeholder : finalUrl)"
                             onerror="this.onerror=null;this.src='@Placeholder';this.closest('.card-img-wrap')?.classList.add('img-missing')" alt="@c.Name" />
                        <span class="card-watermark">Imagem não localizada</span>
                    </div>

                    <div class="card-info">
                        <span class="card-name">@c.Name</span>
                        <span class="card-meta">
                            <span class="card-number">#@c.Number</span>
                            @if (!string.IsNullOrWhiteSpace(symbolUrl))
                            {
                                <img class="card-symbol" src="@(symbolUrl).png" onerror="this.style.display='none'" alt="" />
                            }
                        </span>
                    </div>

                    @if (mastersetEnabled && variantsByCard.TryGetValue(c.Id, out var cardVariants) && cardVariants.Count >= 2)
                    {
                        <div class="card-variants" @onclick:stopPropagation="true">
                            @foreach (var v in cardVariants)
                            {
                                <label class="variant-chip variant-@v.Type @(v.Owned ? "on" : "")">
                                    <input type="checkbox" checked="@v.Owned"
                                           @onchange="e => ToggleVariant(v.Id, (bool)(e.Value ?? false))" />
                                    @VariantLabel(v.Type)
                                </label>
                            }
                        </div>
                    }
                </div>
            }
        </div>
    }
}

@* ── Modal ── *@
@if (modalCard is not null)
{
    <div class="modal-overlay" @onclick="CloseModal">
        <div class="modal-card" @onclick:stopPropagation="true">
            <img class="modal-img" src="@(string.IsNullOrWhiteSpace(modalCard.ImageSmallUrl) ? Placeholder : PokeCollection.Data.CardImage.BuildUrl(modalCard.ImageSmallUrl, "high", "webp"))" alt="@modalCard.Name"
                 onerror="this.onerror=null;this.src='@Placeholder'" />

            <div class="modal-info">
                <span class="modal-name">@modalCard.Name</span>
                <span class="modal-number">#@modalCard.Number</span>
                @if (!string.IsNullOrWhiteSpace(modalCard.Rarity))
                {
                    <span class="modal-rarity">@modalCard.Rarity</span>
                }
            </div>

            <button class="modal-close" @onclick="CloseModal">
                <span class="oi oi-x"></span> Fechar
            </button>
        </div>
    </div>
}

@code {
    [Parameter] public int SetId { get; set; }

    private const string Placeholder = PokeCollection.Data.CardImage.Placeholder;

    private PokemonSet? set;
    private List<PokemonCard> cards = new();

    private bool isLoading = true;
    private string loadingStatus = "Carregando...";
    private int newCardsAdded = 0;
    private int newImagesLoaded = 0;

    private PokemonCard? modalCard;
    private string? missingLog;
    private int missingCount;

    private enum CardFilter { Todas, Faltantes, Adquiridas }
    private CardFilter cardFilter = CardFilter.Todas;
    private string cardNameFilter = "";

    private bool mastersetEnabled;
    private Dictionary<int, List<CardVariant>> variantsByCard = new();

    private IEnumerable<PokemonCard> FilteredCards
    {
        get
        {
            var filtered = cardFilter switch
            {
                CardFilter.Faltantes  => cards.Where(c => !c.Owned),
                CardFilter.Adquiridas => cards.Where(c => c.Owned),
                _                     => cards.AsEnumerable()
            };
            if (!string.IsNullOrWhiteSpace(cardNameFilter))
                filtered = filtered.Where(c => PokeCollection.Data.CardSearch.Matches(c.Name, c.Number, cardNameFilter));
            return filtered;
        }
    }

    private void OpenModal(PokemonCard card) => modalCard = card;
    private void CloseModal() => modalCard = null;

    private void ToggleMissingLog()
    {
        if (missingLog is not null)
        {
            missingLog = null;
            return;
        }

        var missing = cards.Where(c => !c.Owned).ToList();
        missingCount = missing.Count;
        if (missing.Count == 0)
        {
            missingLog = "Todas as cartas desta coleção foram adquiridas!";
            return;
        }

        var total = cards.Count;
        missingLog = string.Join("\n", missing.Select(c => $"1 {c.Name} ({c.Number}/{total}) [QUALIDADE=NM] [IDIOMA=PT]"));
    }

    private async Task CopyLog()
    {
        if (!string.IsNullOrEmpty(missingLog))
            await JS.InvokeVoidAsync("clipboardHelper.copy", missingLog);
    }

    protected override async Task OnInitializedAsync()
    {
        set = await Db.Sets.AsNoTracking().FirstOrDefaultAsync(x => x.Id == SetId);
        cards = await ReloadCards();

        _ = SyncInBackground();
    }

    private async Task SyncInBackground()
    {
        try
        {
            if (set is null)
            {
                isLoading = false;
                StateHasChanged();
                return;
            }

            loadingStatus = "Sincronizando cartas...";
            StateHasChanged();

            var (ok, _, apiCards, officialTotal) = await Api.GetCardsBySetAsync(set.ExternalId);

            if (ok && set.TotalCards == 0 && officialTotal > 0)
            {
                var setEntity = await Db.Sets.FirstOrDefaultAsync(x => x.Id == SetId);
                if (setEntity is not null)
                {
                    setEntity.TotalCards = officialTotal;
                    await Db.SaveChangesAsync();
                    set = await Db.Sets.AsNoTracking().FirstOrDefaultAsync(x => x.Id == SetId);
                }
            }

            if (ok && apiCards.Count > 0)
            {
                var existingIds = new HashSet<string>(
                    await Db.Cards
                        .Where(x => x.PokemonSetId == SetId)
                        .Select(x => x.ExternalId)
                        .ToListAsync()
                );

                int added = 0;
                foreach (var c in apiCards)
                {
                    if (string.IsNullOrWhiteSpace(c.id) || existingIds.Contains(c.id)) continue;

                    Db.Cards.Add(new PokemonCard
                    {
                        ExternalId    = c.id,
                        PokemonSetId  = SetId,
                        Name          = c.name ?? "",
                        Number        = c.localId ?? "",
                        Rarity        = c.rarity ?? "",
                        ImageSmallUrl = "",
                        Owned         = false
                    });
                    added++;
                }

                if (added > 0)
                {
                    await Db.SaveChangesAsync();
                    newCardsAdded = added;
                    cards = await ReloadCards();
                }
            }

            var setCards = await Db.Cards
                .Where(x => x.PokemonSetId == SetId)
                .ToListAsync();

            var setCardIds = setCards.Select(c => c.Id).ToList();
            var withVariants = new HashSet<int>(
                await Db.CardVariants
                    .Where(v => setCardIds.Contains(v.PokemonCardId))
                    .Select(v => v.PokemonCardId)
                    .Distinct()
                    .ToListAsync()
            );

            var pending = setCards
                .Where(c => string.IsNullOrWhiteSpace(c.ImageSmallUrl) || !withVariants.Contains(c.Id))
                .OrderBy(CardNumberSortKey).ThenBy(c => c.Number)
                .ToList();

            const int foregroundBatch = 30;
            int done = 0;
            int total = pending.Count;
            int pendingSave = 0;

            foreach (var card in pending)
            {
                done++;
                if (isLoading)
                {
                    loadingStatus = $"Carregando cartas... {done}/{Math.Min(total, foregroundBatch)}";
                    StateHasChanged();
                }
                await Task.Yield();

                var (detOk, _, details) = await Api.GetCardDetailsAsync(card.ExternalId);
                if (detOk && details is not null)
                {
                    if (string.IsNullOrWhiteSpace(card.ImageSmallUrl))
                    {
                        var url = PokemonApiService.ExtractFinalImageUrlFromDetails(details);
                        if (string.IsNullOrWhiteSpace(url))
                        {
                            var (fbOk, _, fbUrl) = await Api.GetFallbackImageAsync(card.Name, card.Number, set?.TotalCards ?? 0);
                            if (fbOk) url = fbUrl;
                        }
                        if (!string.IsNullOrWhiteSpace(url))
                        {
                            card.ImageSmallUrl = url;
                            newImagesLoaded++;
                        }
                    }

                    if (!withVariants.Contains(card.Id))
                    {
                        foreach (var type in PokemonApiService.ExtractVariantTypesFromDetails(details))
                            Db.CardVariants.Add(new CardVariant { PokemonCardId = card.Id, Type = type, Owned = false });
                    }
                    pendingSave++;
                }

                var revealNow = isLoading && (done >= foregroundBatch || done == total);
                if (revealNow || pendingSave >= 10)
                {
                    if (pendingSave > 0) await Db.SaveChangesAsync();
                    pendingSave = 0;
                    cards = await ReloadCards();
                    await ReloadVariantsByCard();
                    if (revealNow) isLoading = false;
                    StateHasChanged();
                }
            }

            if (pendingSave > 0)
            {
                await Db.SaveChangesAsync();
                cards = await ReloadCards();
                await ReloadVariantsByCard();
                StateHasChanged();
            }
        }
        catch
        {
            loadingStatus = "Erro ao sincronizar. Tente novamente.";
            StateHasChanged();
            await Task.Delay(2500);
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task<List<PokemonCard>> ReloadCards()
    {
        var list = await Db.Cards.AsNoTracking()
            .Where(x => x.PokemonSetId == SetId)
            .ToListAsync();
        return list.OrderBy(CardNumberSortKey).ThenBy(x => x.Number).ToList();
    }

    private static int CardNumberSortKey(PokemonCard c) =>
        int.TryParse(c.Number, out var n) ? n : int.MaxValue;

    private async Task ToggleOwned(int cardId, bool owned)
    {
        var card = await Db.Cards.FirstOrDefaultAsync(x => x.Id == cardId);
        if (card is null) return;
        card.Owned = owned;
        card.AcquiredAt = owned ? DateTime.UtcNow : null;
        await Db.SaveChangesAsync();
        var idx = cards.FindIndex(x => x.Id == cardId);
        if (idx >= 0)
        {
            cards[idx].Owned = owned;
            cards[idx].AcquiredAt = card.AcquiredAt;
        }
    }

    private async Task ToggleMasterset()
    {
        mastersetEnabled = !mastersetEnabled;
        if (mastersetEnabled)
            await ReloadVariantsByCard();
    }

    private async Task ReloadVariantsByCard()
    {
        var cardIds = cards.Select(c => c.Id).ToList();

        var all = await Db.CardVariants.AsNoTracking()
            .Where(v => cardIds.Contains(v.PokemonCardId))
            .ToListAsync();

        variantsByCard = all
            .GroupBy(v => v.PokemonCardId)
            .ToDictionary(
                g => g.Key,
                g => g.OrderBy(v => Array.IndexOf(PokemonApiService.KnownVariantTypes, v.Type)).ToList()
            );
    }

    private async Task ToggleVariant(int variantId, bool owned)
    {
        var variant = await Db.CardVariants.FirstOrDefaultAsync(v => v.Id == variantId);
        if (variant is null) return;
        variant.Owned = owned;
        await Db.SaveChangesAsync();

        if (variantsByCard.TryGetValue(variant.PokemonCardId, out var list))
        {
            var item = list.FirstOrDefault(v => v.Id == variantId);
            if (item is not null) item.Owned = owned;
        }
    }

    private static string VariantLabel(string type) => type switch
    {
        "normal"       => "Normal",
        "reverse"      => "Reverse",
        "holo"         => "Holo",
        "firstEdition" => "1ª Ed.",
        "wPromo"       => "Promo",
        _              => type
    };
}
