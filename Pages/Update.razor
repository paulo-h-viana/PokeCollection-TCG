@page "/update"
@using Velopack
@using Velopack.Sources

<div class="update-container">
    <h2>Atualização do Sistema</h2>
    <p>Verifique se há novas versões do PokeCollection disponíveis para download.</p>
    
    <div class="mt-4">
        <button class="btn btn-primary" @onclick="CheckForUpdatesAsync" disabled="@_isChecking">
            @(_isChecking ? "Verificando..." : "Verificar Atualização")
        </button>
    </div>

    @if (!string.IsNullOrWhiteSpace(_message))
    {
        <div class="alert alert-info mt-3">
            @_message
        </div>
    }

    @if (_updateInfo is not null)
    {
        <div class="mt-3">
            <button class="btn btn-success" @onclick="ApplyUpdateAsync" disabled="@_isUpdating">
                @(_isUpdating ? "Baixando e Reiniciando..." : "Instalar Atualização")
            </button>
        </div>
    }
</div>

@code {
    private bool _isChecking;
    private bool _isUpdating;
    private string? _message;
    private UpdateInfo? _updateInfo;
    
    private const string GithubRepoUrl = "https://github.com/paulo-h-viana/PokeCollection-TCG";

    private async Task CheckForUpdatesAsync()
    {
        _isChecking = true;
        _message = null;
        _updateInfo = null;

        try
        {
            var source = new GithubSource(GithubRepoUrl, accessToken: null, prerelease: false);
            var mgr = new UpdateManager(source);
            
            if (!mgr.IsInstalled)
            {
                _message = "O aplicativo não está instalado via Velopack (rodando em modo de desenvolvimento).";
                return;
            }

            _updateInfo = await mgr.CheckForUpdatesAsync();

            _message = _updateInfo is not null 
                ? $"Nova versão ({_updateInfo.TargetFullRelease.Version}) encontrada. Pronta para baixar." 
                : "O aplicativo já está na versão mais recente.";
        }
        catch (Exception ex)
        {
            _message = $"Falha ao verificar: {ex.Message}";
        }
        finally
        {
            _isChecking = false;
        }
    }

    private async Task ApplyUpdateAsync()
    {
        if (_updateInfo is null) return;
        _isUpdating = true;
        _message = "Baixando arquivos... o aplicativo será reiniciado em instantes.";

        try
        {
            var source = new GithubSource(GithubRepoUrl, accessToken: null, prerelease: false);
            var mgr = new UpdateManager(source);
            await mgr.DownloadUpdatesAsync(_updateInfo);
            mgr.ApplyUpdatesAndRestart(_updateInfo);
        }
        catch (Exception ex)
        {
            _message = $"Erro durante atualização: {ex.Message}";
            _isUpdating = false;
        }
    }
}
