@page "/sets"
@using Microsoft.EntityFrameworkCore
@using PokeCollection.Data.Models
@inject PokeCollection.Data.AppDbContext Db
@inject PokeCollection.Data.Services.PokemonApiService Api

<div class="sets-header">
    <h3>Coleções</h3>
    <input class="search-input" placeholder="Buscar coleção..."
           @oninput="e => searchTerm = e.Value?.ToString() ?? string.Empty" />
</div>

@if (newCount > 0)
{
    <div class="sync-toast">
        <span class="sync-toast-icon">✨</span>
        <span>@newCount nova@(newCount > 1 ? "s coleções adicionadas" : " coleção adicionada")!</span>
    </div>
}
@if (!string.IsNullOrWhiteSpace(syncError))
{
    <div class="sync-toast sync-toast-error">
        <span class="sync-toast-icon">⚠️</span>
        <span>@syncError</span>
    </div>
}

@if (sets is null)
{
    <p>Carregando...</p>
}
else if (!FilteredSets.Any())
{
    <p>Nenhuma coleção encontrada.</p>
}
else
{
    <div class="sets-grid">
        @foreach (var s in FilteredSets)
        {
            var owned = ownedCounts.GetValueOrDefault(s.Id, 0);
            var total = s.TotalCards;
            var pct   = total > 0 ? (int)((double)owned / total * 100) : 0;
            var barClass = pct >= 75 ? "bar-green" : pct >= 25 ? "bar-yellow" : "bar-red";

            <a class="set-card" href="/cards/@s.Id">
                <div class="set-img-wrap">
                    <img src="/images/sets/@(s.ExternalId).png"
                         alt="@s.Name"
                         onerror="this.onerror=null;this.src='/images/header-logo.png'" />
                </div>
                <div class="set-info">
                    <span class="set-name">@s.Name</span>
                    <span class="set-series">@s.Series</span>
                </div>
                @if (total > 0)
                {
                    <div class="set-progress-wrap">
                        <div class="set-progress-track">
                            <div class="set-progress-fill @barClass" style="width: @pct%"></div>
                        </div>
                        <span class="set-progress-label">@owned/@total</span>
                    </div>
                }
            </a>
        }
    </div>
}

@code {
    private List<PokemonSet>? sets;
    private Dictionary<int, int> ownedCounts = new();
    private int newCount = 0;
    private string? syncError;
    private string searchTerm = "";

    private IEnumerable<PokemonSet> FilteredSets =>
        sets is null ? Enumerable.Empty<PokemonSet>() :
        string.IsNullOrWhiteSpace(searchTerm)
            ? sets
            : sets.Where(s => s.Name.Contains(searchTerm, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        sets = await Db.Sets.AsNoTracking()
            .OrderBy(s => s.Name)
            .ToListAsync();

        await LoadOwnedCounts();

        _ = SyncInBackground();
    }

    private async Task LoadOwnedCounts()
    {
        var counts = await Db.Cards
            .AsNoTracking()
            .Where(c => c.Owned)
            .GroupBy(c => c.PokemonSetId)
            .Select(g => new { SetId = g.Key, Count = g.Count() })
            .ToListAsync();
        ownedCounts = counts.ToDictionary(x => x.SetId, x => x.Count);
    }

    private async Task SyncInBackground()
    {
        try
        {
            var (ok, _, apiSets) = await Api.GetSetsAsync();
            if (!ok) return;

            int added = 0;
            int updated = 0;
            foreach (var s in apiSets)
            {
                if (!System.Text.RegularExpressions.Regex.IsMatch(s.id, @"^[a-zA-Z0-9\-\.]+$"))
                    continue;

                var existing = await Db.Sets.FirstOrDefaultAsync(x => x.ExternalId == s.id);
                if (existing is null)
                {
                    Db.Sets.Add(new PokemonSet
                    {
                        ExternalId = s.id,
                        Name       = s.name,
                        Series     = string.IsNullOrWhiteSpace(s.serie) ? "" : s.serie,
                        TotalCards = s.cardCount.official
                    });
                    added++;
                }
                else if (existing.TotalCards == 0 && s.cardCount.official > 0)
                {
                    existing.TotalCards = s.cardCount.official;
                    updated++;
                }
            }

            if (added > 0 || updated > 0)
            {
                await Db.SaveChangesAsync();
                sets = await Db.Sets.AsNoTracking()
                    .OrderBy(x => x.Name)
                    .ToListAsync();
                newCount = added;
                StateHasChanged();
            }
        }
        catch
        {
            syncError = "Erro ao sincronizar coleções. Tente novamente.";
            StateHasChanged();
        }
    }
}
