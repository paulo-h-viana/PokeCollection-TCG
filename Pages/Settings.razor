@page "/settings"
@using PokeCollection.Data.Services
@inject WindowService WindowSvc
@inject BackupService BackupSvc
@inject IJSRuntime JS

<div class="settings-header">
    <h3>Configurações</h3>
</div>

<div class="settings-section">
    <h4 class="settings-section-title">Aparência</h4>
    <div class="settings-actions">
        <div class="settings-action-card">
            <div class="settings-action-info">
                <span class="settings-action-title">Tema</span>
                <span class="settings-action-desc">Alterna entre modo claro e escuro.</span>
            </div>
            <button class="settings-btn @(isDark ? "settings-btn-dark" : "settings-btn-light")" @onclick="ToggleDarkMode">
                @(isDark ? "☀️ Modo Claro" : "🌙 Modo Escuro")
            </button>
        </div>
    </div>
</div>

<div class="settings-section">
    <h4 class="settings-section-title">Backup e Restauração</h4>
    <p class="settings-section-desc">
        O banco de dados contém todas as suas coleções e cartas adquiridas.
        Faça backups regularmente para não perder seu progresso.
    </p>

    <div class="settings-actions">
        <div class="settings-action-card">
            <div class="settings-action-info">
                <span class="settings-action-title">Exportar Backup</span>
                <span class="settings-action-desc">Salva uma cópia do banco de dados no local escolhido.</span>
            </div>
            <button class="settings-btn settings-btn-blue" @onclick="BackupAsync" disabled="@isProcessing">
                💾 Exportar
            </button>
        </div>

        <div class="settings-action-card">
            <div class="settings-action-info">
                <span class="settings-action-title">Restaurar Backup</span>
                <span class="settings-action-desc">Substitui o banco atual por um arquivo de backup. O app será reiniciado.</span>
            </div>
            <button class="settings-btn settings-btn-orange" @onclick="RestoreAsync" disabled="@isProcessing">
                📂 Restaurar
            </button>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(message))
    {
        <div class="settings-message @(isError ? "settings-message-error" : "settings-message-ok")">
            @message
        </div>
    }
</div>

<div class="settings-section">
    <h4 class="settings-section-title">Backup automático (Google Drive)</h4>
    <p class="settings-section-desc">
        Escolha uma pasta sincronizada com o Google Drive. Ao fechar o app, uma cópia
        do banco é salva automaticamente nessa pasta.
    </p>

    <div class="settings-actions">
        <div class="settings-action-card">
            <div class="settings-action-info">
                <span class="settings-action-title">Pasta de backup</span>
                <span class="settings-action-desc">
                    @(string.IsNullOrWhiteSpace(backupFolder) ? "Nenhuma pasta selecionada." : backupFolder)
                </span>
            </div>
            <button class="settings-btn settings-btn-blue" @onclick="ChooseFolderAsync" disabled="@isProcessing">
                📁 Escolher pasta
            </button>
        </div>

        <div class="settings-action-card">
            <div class="settings-action-info">
                <span class="settings-action-title">Backup ao fechar o app</span>
                <span class="settings-action-desc">
                    @(autoEnabled ? "Ativado." : "Desativado.")
                    @if (lastBackup is not null)
                    {
                        <text> Último backup: @lastBackup.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</text>
                    }
                </span>
            </div>
            <button class="settings-btn @(autoEnabled ? "settings-btn-orange" : "settings-btn-blue")"
                    @onclick="ToggleAutoBackup" disabled="@(isProcessing || string.IsNullOrWhiteSpace(backupFolder))">
                @(autoEnabled ? "Desativar" : "Ativar")
            </button>
        </div>

        <div class="settings-action-card">
            <div class="settings-action-info">
                <span class="settings-action-title">Fazer backup agora</span>
                <span class="settings-action-desc">Salva uma cópia imediatamente na pasta escolhida.</span>
            </div>
            <button class="settings-btn settings-btn-blue" @onclick="BackupNowAsync"
                    disabled="@(isProcessing || string.IsNullOrWhiteSpace(backupFolder))">
                ⏱️ Backup agora
            </button>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(autoMessage))
    {
        <div class="settings-message @(autoIsError ? "settings-message-error" : "settings-message-ok")">
            @autoMessage
        </div>
    }
</div>

@code {
    private bool isDark = false;
    private bool isProcessing = false;
    private bool isError = false;
    private string? message;

    private string? backupFolder;
    private bool autoEnabled;
    private DateTime? lastBackup;
    private bool autoIsError = false;
    private string? autoMessage;

    protected override void OnInitialized()
    {
        var config = BackupSvc.GetConfig();
        backupFolder = config.BackupFolder;
        autoEnabled = config.AutoBackupEnabled;
        lastBackup = config.LastBackupUtc;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            isDark = await JS.InvokeAsync<bool>("darkMode.get");
            StateHasChanged();
        }
    }

    private async Task ToggleDarkMode()
    {
        isDark = await JS.InvokeAsync<bool>("darkMode.toggle");
    }

    private async Task BackupAsync()
    {
        isProcessing = true;
        message = null;
        isError = false;

        try
        {
            var defaultName = $"PokeCollection_backup_{DateTime.Now:yyyy-MM-dd}.db";
            var destPath = await Task.Run(() => WindowSvc.ShowSaveFileDialog("Banco de dados SQLite|*.db", defaultName));

            if (destPath is null)
            {
                isProcessing = false;
                return;
            }

            await Task.Run(() => BackupSvc.CreateBackupToFile(destPath));
            message = "Backup exportado com sucesso!";
        }
        catch (Exception ex)
        {
            isError = true;
            message = $"Erro ao exportar: {ex.Message}";
        }
        finally
        {
            isProcessing = false;
        }
    }

    private async Task RestoreAsync()
    {
        isProcessing = true;
        message = null;
        isError = false;

        try
        {
            var sourcePath = await Task.Run(() => WindowSvc.ShowOpenFileDialog("Banco de dados SQLite|*.db"));
            if (sourcePath is null)
            {
                isProcessing = false;
                return;
            }

            await Task.Run(() => BackupSvc.RestoreFromFile(sourcePath));

            message = "Backup restaurado. Reiniciando...";
            StateHasChanged();
            await Task.Delay(1500);
            WindowSvc.RestartApplication();
        }
        catch (Exception ex)
        {
            isError = true;
            message = $"Erro ao restaurar: {ex.Message}";
            isProcessing = false;
        }
    }

    private async Task ChooseFolderAsync()
    {
        autoMessage = null;
        autoIsError = false;

        var initial = backupFolder ?? BackupService.SuggestGoogleDriveFolder();
        var folder = await Task.Run(() => WindowSvc.ShowFolderBrowserDialog(initial));
        if (folder is null) return;

        BackupSvc.UpdateFolder(folder);
        backupFolder = folder;
        autoMessage = "Pasta de backup definida.";
    }

    private void ToggleAutoBackup()
    {
        if (string.IsNullOrWhiteSpace(backupFolder)) return;

        autoEnabled = !autoEnabled;
        BackupSvc.SetAutoBackup(autoEnabled);
        autoIsError = false;
        autoMessage = autoEnabled
            ? "Backup automático ativado. Será feito ao fechar o app."
            : "Backup automático desativado.";
    }

    private async Task BackupNowAsync()
    {
        if (string.IsNullOrWhiteSpace(backupFolder)) return;

        isProcessing = true;
        autoMessage = null;
        autoIsError = false;

        try
        {
            var path = await Task.Run(() => BackupSvc.CreateBackupToFolder(backupFolder));
            lastBackup = DateTime.UtcNow;
            autoMessage = $"Backup salvo em: {path}";
        }
        catch (Exception ex)
        {
            autoIsError = true;
            autoMessage = $"Erro ao fazer backup: {ex.Message}";
        }
        finally
        {
            isProcessing = false;
        }
    }
}
